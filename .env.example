# ========================================
# SecureShield Enterprise Configuration
# ========================================

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/secureshield
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ (Celery Broker)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# Security Keys
SECRET_KEY=replace-with-secure-random-string-min-32-chars
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Encryption (HashiCorp Vault)
ENCRYPTION_VAULT_URL=http://vault:8200
ENCRYPTION_VAULT_TOKEN=replace-with-vault-token
ENCRYPTION_USE_HSM=false

# AI/ML
AI_MODEL_PATH=./backend/models/sql_injection_model.pkl
AI_MODEL_VERSION=2.0.0
AI_INFERENCE_SERVICE_URL=http://ai-service:8001
AI_INFERENCE_TIMEOUT=30

# Multi-Tenancy
MULTI_TENANT_ENABLED=true
TENANT_ISOLATION_ENABLED=true

# OpenTelemetry (Distributed Tracing)
OPENTELEMETRY_ENABLED=true
OPENTELEMETRY_ENDPOINT=http://jaeger:4317
OPENTELEMETRY_SERVICE_NAME=secureshield-backend

# Jaeger
JAEGER_ENABLED=true
JAEGER_HOST=localhost
JAEGER_PORT=6831

# Zero Trust Security
ZERO_TRUST_ENABLED=true
DEVICE_FINGERPRINT_ENABLED=true
BEHAVIORAL_ANALYTICS_ENABLED=true
ADAPTIVE_MFA_ENABLED=true
SESSION_RISK_SCORING_ENABLED=true
TRUST_SCORE_THRESHOLD=0.5

# SIEM Integration
SPLUNK_URL=https://splunk.example.com:8088
SPLUNK_TOKEN=replace-with-splunk-token
SPLUNK_INDEX=secureshield

AZURE_SENTINEL_ENABLED=false
AZURE_SENTINEL_WORKSPACE_ID=
AZURE_SENTINEL_KEY=

QRADAR_ENABLED=false
QRADOR_HOST=
QRADAR_PORT=514

# Threat Intelligence
ALIENVAULT_ENABLED=false
ALIENVAULT_API_KEY=
ABUSEIPDB_ENABLED=false
ABUSEIPDB_API_KEY=
VIRUSTOTAL_ENABLED=false
VIRUSTOTAL_API_KEY=
MISP_ENABLED=false
MISP_URL=https://misp.example.com
MISP_API_KEY=

# API Gateway
KONG_URL=http://kong:8001
TRAEFIK_ENABLED=true

# Stripe Billing
STRIPE_ENABLED=false
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

BILLING_CYCLE_DAYS=30
DEFAULT_API_QUOTA=10000
DEFAULT_STORAGE_QUOTA_MB=1000

# MLflow
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=secureshield

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Logging
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_STORAGE=redis

# API Versioning
API_VERSIONING_ENABLED=true
API_DEFAULT_VERSION=v1
