{
  "dashboard": {
    "title": "SecureShield - Security Operations Dashboard",
    "uid": "secureshield-security",
    "tags": ["security", "sql-injection", "ai-detection"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Total Attacks Blocked",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
        "targets": [{
          "expr": "sum(secureshield_attacks_total)",
          "legendFormat": "Total Attacks"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 100, "color": "yellow"},
                {"value": 500, "color": "red"}
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 2,
        "title": "Attacks (Last 24h)",
        "type": "graph",
        "gridPos": {"x": 4, "y": 0, "w": 12, "h": 8},
        "targets": [{
          "expr": "sum(rate(secureshield_attacks_total[5m])) by (attack_type)",
          "legendFormat": "{{attack_type}}"
        }],
        "xAxis": {"mode": "time"}
      },
      {
        "id": 3,
        "title": "AI Detection Confidence",
        "type": "gauge",
        "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
        "targets": [{
          "expr": "avg(secureshield_ai_confidence)",
          "legendFormat": "Avg Confidence"
        }],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"value": 0.5, "color": "red"},
                {"value": 0.7, "color": "yellow"},
                {"value": 0.9, "color": "green"}
              ]
            },
            "unit": "percentunit"
          }
        }
      },
      {
        "id": 4,
        "title": "Attack by Severity",
        "type": "piechart",
        "gridPos": {"x": 0, "y": 8, "w": 6, "h": 8},
        "targets": [{
          "expr": "sum(secureshield_attacks_total) by (severity)",
          "legendFormat": "{{severity}}"
        }]
      },
      {
        "id": 5,
        "title": "Top Attacking IPs",
        "type": "table",
        "gridPos": {"x": 6, "y": 8, "w": 10, "h": 8},
        "targets": [{
          "expr": "topk(10, sum(secureshield_attacks_total) by (ip_address))",
          "legendFormat": "{{ip_address}}"
        }]
      },
      {
        "id": 6,
        "title": "Request Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
        "targets": [{
          "expr": "rate(secureshield_http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}}"
        }]
      },
      {
        "id": 7,
        "title": "Database Connections",
        "type": "graph",
        "gridPos": {"x": 12, "y": 16, "w": 8, "h": 8},
        "targets": [{
          "expr": "pg_stat_database_numbackends",
          "legendFormat": "Active Connections"
        }]
      },
      {
        "id": 8,
        "title": "Redis Memory",
        "type": "gauge",
        "gridPos": {"x": 16, "y": 16, "w": 4, "h": 4},
        "targets": [{
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes",
          "legendFormat": "Memory Usage"
        }],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"value": 0.7, "color": "yellow"},
                {"value": 0.9, "color": "red"}
              ]
            },
            "unit": "percentunit"
          }
        }
      },
      {
        "id": 9,
        "title": "Active Blocked IPs",
        "type": "stat",
        "gridPos": {"x": 16, "y": 20, "w": 4, "h": 4},
        "targets": [{
          "expr": "secureshield_blocked_ips_total",
          "legendFormat": "Blocked IPs"
        }]
      }
    ],
    "templating": {
      "list": []
    },
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m"]
    }
  },
  "meta": {
    "type": "db",
    "canSave": true,
    "canEdit": true,
    "canAdmin": true
  }
}